FROM golang:1.22-alpine AS builder
WORKDIR /build
COPY go.mod ./
COPY cmd/ ./cmd/
COPY internal/ ./internal/
RUN go mod tidy && CGO_ENABLED=0 go build -o /build/mesh-node ./cmd/node

FROM alpine:3.20
RUN apk add --no-cache iputils
COPY --from=builder /build/mesh-node /mesh-node
EXPOSE 58081
ENTRYPOINT ["/mesh-node"]
